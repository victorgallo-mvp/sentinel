# ============================================================
# SENTINELA ADS — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores
# ============================================================

# --- Banco de dados ---
MONGO_URI=mongodb://localhost:27017/sentinela-ads
DATABASE_URL=postgresql://usuario:senha@host:5432/sentinela_ads
REDIS_URL=redis://localhost:6379

# --- Anthropic ---
ANTHROPIC_API_KEY=
MODELO_TRIAGEM=claude-haiku-4-5
MODELO_AGENTE=claude-sonnet-4-5

# --- Meta (Facebook/Instagram Ads) ---
META_APP_ID=
META_APP_SECRET=
META_SYSTEM_USER_TOKEN=
META_BM_ID=
META_API_VERSION=v21.0

# --- Evolution API (notificação WhatsApp) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# --- Conta atual (mono-tenant operacional) ---
CONTA_ID=victor-pessoal
NOTIFICACAO_WHATSAPP_JID=

# --- Google Sheets (opcional) ---
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Limites e segurança ---
LIMITE_CUSTO_DIARIO_USD=3.00
MAX_ITERACOES_AGENTE=10

# --- Servidor ---
# URL pública da aplicação (Railway), usada para montar links de relatórios
URL_BASE=
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
ADMIN_TOKEN=
